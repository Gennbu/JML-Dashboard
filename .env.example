
# .env.example - Plantilla de Variables de Entorno
# Copia este archivo como .env y rellena los datos con tus credenciales

# Django (seguridad)
# Puedes usar la misma que en settings.py o generar una con:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=tu-clave-secreta-aqui

# Brevo (Envío de Correos)
EMAIL_HOST_USER=tu-correo-verificado-aqui@empresa.com
EMAIL_HOST_PASSWORD=tu-api-key-brevo-aqui

# Para desarrollo local (SÓLO para tu PC)
DEBUG=True
